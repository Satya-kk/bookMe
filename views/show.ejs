<% layout("/layout/boilerplate")-%>

    <body>
        <div class="row mt-3">
            <div class="col-6 offset-3">
                <h2>
                    <%=listing.title%>
                </h2>

                <div class="card listing-card">
                    <img src="<%=listing.image.url%>" class="card-img-top show-img" alt="listing_image">
                    <div class="card-body">
                        <p class="card-text"><i>
                                Owned by <%=listing.owner.username%>
                            </i></p>
                        <p class="card-text">Details:
                        <p>
                            <%=listing.description%>
                        </p>
                        <p>&#8377; <%=listing.price.toLocaleString("en-IN")%>/night</p>
                        <p>
                            <%=listing.location%>
                        </p>
                        <p>
                            <%=listing.country%>
                        </p>
                        </p>
                    </div>
                </div>
                <a href="/listing"><button class="btn btn-secondary">Back</button></a> <br><br>
                <% if(currUser && currUser._id.equals(listing.owner._id)) {%>
                    <div class="btn-style">
                        <a href="/listing/<%=listing._id%>/edit"><button class="btn btn-dark">Edit Property</button></a>
                        <form action="/listing/<%= listing._id %>?_method=DELETE" method="POST">
                            <button type="submit" class="btn btn-danger">Delete</button><br>
                        </form>
                    </div>
                    <%}%>
            </div>

            <!-- review -->

            <div class="col-6 offset-3">
                
                <%if(currUser){%>
                    <hr>
                    <h4>Review</h4>
                    <form action="/listing/<%=listing.id%>/reviews" method="POST" class=" needs-validation" novalidate>
                        <div class=" mt-3">
                            <label for="rating" class="form-label">Rating:</label>
                            <fieldset class="starability-slot">
                                <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0"
                                    checked aria-label="No rating." />
                                <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                                <label for="first-rate1" title="Terrible">1 star</label>
                                <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                                <label for="first-rate2" title="Not good">2 stars</label>
                                <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                                <label for="first-rate3" title="Average">3 stars</label>
                                <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                                <label for="first-rate4" title="Very good">4 stars</label>
                                <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                                <label for="first-rate5" title="Amazing">5 stars</label>
                            </fieldset>
                        </div>
                        <div class="mb-3">
                            <label for="comment" class="form-label">Comments:</label>
                            <textarea name="review[comment]" id="comment" cols="30" rows="5"
                                placeholder="Write a comment" class="form-control" required></textarea>
                            <div class="invalid-feedback">
                                Please enter comment!
                            </div>
                        </div>
                        <button class="btn btn-outline-dark mb-3">Submit</button>
                    </form>
                    <%}%>

                        <%if(listing.reviews.length>0) {%>
                        <div class="row">
                            <hr>
                                <p><b>All reviews</b></p>
                            <% for (let review of listing.reviews) { %>
                                <div class="card col-5 ms-3 mb-3">
                                    <div class="card-body">
                                        <h6 class="card-title"><i>@<%=review.createdBy.username%></i></h6>
                                        <p class="starability-result card-text" data-rating=<%=review.rating%>></p>
                                        <p class="card-text">
                                            <%= review.comment%>
                                        </p>
                                    </div>
                                    <% if(currUser && currUser._id.equals(review.createdBy._id)) {%>
                                        <form action="/listing/<%=listing._id%>/reviews/<%=review._id%>?_method=DELETE"
                                            class="mb-3 mt-3" method="POST">
                                            <button class="btn btn-sm btn-dark">Delete</button>
                                        </form>
                                        <% } %>
                                </div>
                                <% } %>
                        </div>
                        <%}%>
            </div>
        </div>
        <br>
    </body>